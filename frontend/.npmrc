# pnpm v10 reads ONLY auth/registry settings from .npmrc. Everything else
# (overrides, minimumReleaseAge, preferOffline, autoInstallPeers, ...) lives in
# pnpm-workspace.yaml — putting them here silently no-ops them.

registry=https://registry.npmjs.org/

# Strict SSL when connecting to the registry (auth/registry setting).
strict-ssl=true
